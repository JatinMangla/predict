# ── Auth (required) ────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32   (or any long random string)
AUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local):      http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (production): https://YOUR-APP.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# The ONLY email allowed to sign in
ALLOWED_EMAIL=jatinmangla123@gmail.com

# ── AI fallback (optional — app works fully without these) ─────────
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=
# Fallback: Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
